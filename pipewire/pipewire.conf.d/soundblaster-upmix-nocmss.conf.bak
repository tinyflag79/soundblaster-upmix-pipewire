#
# Author tinyflag
# Date 2026-04-18
# Name soundblaster upmix without cmss_ent
# Description upmix Surround enhanced using butter worth and hilbert
#             add gain control for each channel 
#             adjust gain for suitable sound that reach to you, different size of room might be different gain on each front center and rear sound 
#



context.properties = {
    resample.quality = 10
}
context.modules = [
{   name = libpipewire-module-filter-chain
    args = {
        node.description = "SoundBlaster SBX 5.1"
        media.name       = "SoundBlaster SBX 5.1"
        filter.graph = {
            nodes = [
                # Bridge nodes to accept Stereo input
                { type = builtin label = copy name = keepL }
                { type = builtin label = copy name = keepR }

                 
                #
                # --- REAR SOUND SECTION ---
                #
                # 7.0. Front Channel Extraction using para eq
                {
                    type   = lv2
                    name   = cleanRLR
                    plugin = "http://lsp-plug.in/plugins/lv2/para_equalizer_x8_ms"
                    control = {
                        "lstn" = 1.0     # 0.0 = Standard Stereo Output
                        "gain_m" = 0.3   # Mute the Center (Vocals)
                        "gain_s" = 1.0   # Keep the Stereo Sides
                    }
                }
                
                # 1a. use Allpass to remove Center sound from Rear
                {
                    type = lv2
                    name = rear_ap_L
                    plugin = "http://lsp-plug.in/plugins/lv2/filter_mono"
                    control = {
                        "ft" = 10        # 10 is the magic number for Allpass
                        "f"  = 1000      # Center frequency for Left
                        "q"  = 0.7       # Resonance/Width
                    }
                }
                # 1b. use Allpass to remove Center sound from Rear
                {
                    type = lv2
                    name = rear_ap_R
                    plugin = "http://lsp-plug.in/plugins/lv2/filter_mono"
                    control = {
                        "ft" = 10        # Allpass
                        "f"  = 1400      # Slightly different frequency for Right
                        "q"  = 0.7
                    }
                }

                # 2. Hilbert Phase Shifting (The 3D bubble effect)
                {
                       type = builtin
                       name = hilRL
                       label = convolver
                       config = {
                           filename = "/hilbert"
                           length = 1024
                           delay = 0.015
                           gain = 1.0
                       }
                }
                {
                       type = builtin
                       name = hilRR
                       label = convolver
                       config = {
                           filename = "/hilbert"
                           length = 1024
                           delay = 0.015
                           gain = -1.0
                       }
                }


                # 3. Rear High Pass Low Pass stereo split
                {
                    name = rear_lpL
                    type = ladspa
                    plugin = /usr/lib/ladspa/butterworth_1902.so
                    label = buttlow_iir
                    control = {
                        "Cutoff Frequency (Hz)" = 6500
                        "Resonance" = 0.707
                    }
                }
                {
                    name = rear_hpL
                    type = ladspa
                    plugin = /usr/lib/ladspa/butterworth_1902.so
                    label = butthigh_iir
                    control = {
                        "Cutoff Frequency (Hz)" = 500
                        "Resonance" = 0.707
                    }
                }
                {
                    name = rear_lpR
                    type = ladspa
                    plugin = /usr/lib/ladspa/butterworth_1902.so
                    label = buttlow_iir
                    control = {
                        "Cutoff Frequency (Hz)" = 6500
                        "Resonance" = 0.707
                    }
                }
                {
                    name = rear_hpR
                    type = ladspa
                    plugin = /usr/lib/ladspa/butterworth_1902.so
                    label = butthigh_iir
                    control = {
                        "Cutoff Frequency (Hz)" = 500
                        "Resonance" = 0.707
                    }
                }

                # 4. Extract the "Rear-only" signal for use in other
                {
                    name   = mixRearLogic
                    type   = builtin
                    label  = mixer
                }


                # 5a. Gain for Rear
                { type = ladspa
                    plugin = "/usr/lib/ladspa/amp.so"
                    label  = "amp_mono"
                    name = rear_gain_L
                        control = { "Gain" = 0.4 }
                }
                # 5b. Gain for Rear
                { type = ladspa
                    plugin = "/usr/lib/ladspa/amp.so"
                    label  = "amp_mono"
                    name = rear_gain_R
                        control = { "Gain" = 0.4 }
                }

                
                
                #
                # --- CENTER SOUND SECTION ---
                #
                # 5. Build the Center by subtracting that Rear signal
                {
                    name   = mixCenterSubRear
                    type   = builtin
                    label  = mixer
                    control = {
                        "Gain 1" = 0.8   # Left
                        "Gain 2" = 0.8   # Right
                        "Gain 3" = -0.4  # Subtract the Rear Logic to "duck" the center
                    }
                }


                # Node 2: Extract Mid signal (Vocals only)
                {
                    type   = lv2
                    name   = vocal_extract
                    plugin = "http://lsp-plug.in/plugins/lv2/para_equalizer_x8_ms"
                    control = {
                        "lstn" = 1.0    # Enable Mid/Side Listen
                        "gain_m" = 1.0  # Keep the Mid (Vocals)
                        "gain_s" = 0.4  # Mute the Side (Music) on this node
                    }
                }

                # 6. Center Channel Boost
                {
                    type = builtin
                    name = eq_Center_Boost
                    label = param_eq
                    config = {
                        filters1 = [
                            { type = bq_lowpass freq = 8000 },
                            # This adds +4 decibels specifically to the Center channel
                            { type = bq_highshelf freq = 0 gain = 6.0 }
                        ]
                    }
                }
                
                # 5b. Gain for center silent test
                { type = ladspa
                    plugin = "/usr/lib/ladspa/amp.so"
                    label  = "amp_mono"
                    name = center_gain_C
                        control = { "Gain" = 0.6 }
                }                

                #
                # --- FRONT LEFT RIGHT SOUND SECTION ---
                #

                # 7. Front Channel Extraction (L - 0.5C / R - 0.5C)
                {
                        name   = subFL
                        type   = builtin
                        label  = mixer
                        control = { "Gain 1" = 1.0 "Gain 2" = -0.6 }
                }
                {
                        name   = subFR
                        type   = builtin
                        label  = mixer
                        control = { "Gain 1" = 1.0 "Gain 2" = -0.6 }
                }

                # 5a. Gain for FRONT
                { type = ladspa
                    plugin = "/usr/lib/ladspa/amp.so"
                    label  = "amp_mono"
                    name = front_gain_L
                        control = { "Gain" = 1.3 }
                }
                # 5b. Gain for FRONT
                { type = ladspa
                    plugin = "/usr/lib/ladspa/amp.so"
                    label  = "amp_mono"
                    name = front_gain_R
                        control = { "Gain" = 1.3 }
                }
                

                #
                # --- LFE BASS SOUND SECTION ---
                #
                # Low-pass front left
                {
                        type   = ladspa
                        name   = lfe_lp_FL
                        plugin = "/usr/lib/ladspa/butterworth_1902.so"
                        label  = "buttlow_iir"
                        control = { "Cutoff Frequency (Hz)" = 120 "Resonance" = 0.707 }
                }

                # Low-pass front right
                {
                        type   = ladspa
                        name   = lfe_lp_FR
                        plugin = "/usr/lib/ladspa/butterworth_1902.so"
                        label  = "buttlow_iir"
                        control = { "Cutoff Frequency (Hz)" = 120 "Resonance" = 0.707 }
                }

                # Mixer to sum channels
                {
                        type = builtin
                        name = lfe_sum
                        label = mixer
                        control = { "Gain 1" = 0.4 "Gain 2" = 0.4 "Gain 3" = 0.2 } # FL + FR + FC
                }





                # 6. High-Pass Filter for Rears (Focusing spatial cues)
                {
                        type = builtin
                        name = eq_Rears
                        label = param_eq
                        config = {
                            filters1 = [ { type = bq_highpass freq = 200 } ]
                            filters2 = [ { type = bq_highpass freq = 200 } ]
                        }
                }

                # Nodes for OUTPUT
                { name = convFL type = builtin label = copy }
                { name = convFR type = builtin label = copy }
                { name = convFC type = builtin label = copy }
                { name = convLFE type = builtin label = copy }
                { name = convRL type = builtin label = copy }
                { name = convRR type = builtin label = copy }

            ]

            # Now we "wire" those 2 inputs to the 6 filter nodes
            links = [


                # REAR: Extract Rear Ambience (L-R / R-L)
                { output = "keepL:Out"  input="rear_gain_L:Input" }
                { output = "keepR:Out"  input="rear_gain_R:Input" }

                { output = "rear_gain_L:Output"  input="cleanRLR:in_l" }
                { output = "rear_gain_R:Output"  input="cleanRLR:in_r" }
                
                # REAR: Extract Rear Sound for Center
                { output = "cleanRLR:out_l" input = "mixRearLogic:In 1" }
                { output = "cleanRLR:out_r" input = "mixRearLogic:In 2" }

                # REAR: Allpass to remove Center sound
                { output = "cleanRLR:out_l"  input="rear_ap_L:in" }
                { output = "cleanRLR:out_r"  input="rear_ap_R:in" }

                # REAR: Hilbert Phase Shifting
                { output = "rear_ap_L:out"  input="hilRL:In" }
                { output = "rear_ap_R:out"  input="hilRR:In" }

                # REAR: Rear LEFT High Pass Low Pass stereo split
                { output = "hilRL:Out"  input="rear_lpL:Input" }
                { output = "rear_lpL:Output"  input="rear_hpL:Input" }

                # REAR: Rear RIGHT High Pass Low Pass stereo split
                { output = "hilRR:Out"  input="rear_lpR:Input" }
                { output = "rear_lpR:Output"  input="rear_hpR:Input" }



                # CENTER: Create Center Sound
                { output = "keepL:Out" input = "vocal_extract:in_l" }
                { output = "keepR:Out" input = "vocal_extract:in_r" }
                
                # CENTER: Create Center Sound
                { output = "vocal_extract:out_l" input = "mixCenterSubRear:In 1" }
                { output = "vocal_extract:out_r" input = "mixCenterSubRear:In 2" }
                { output = "mixRearLogic:Out" input = "mixCenterSubRear:In 3" }
                
                { output = "vocal_extract:out_l" input = "mixCenterSubRearOneSource:In 1" }
                { output = "mixRearLogic:Out" input = "mixCenterSubRearOneSource:In 2" }

                
                # CENTER: Boost
                { output = "mixCenterSubRear:Out"  input="eq_Center_Boost:In 1" }
                { output = "eq_Center_Boost:Out 1"  input="center_gain_C:Input" }


                # FRONT LR: Clean up
                { output = "keepL:Out"     input="subFL:In 1" }
                { output = "mixCenterSubRear:Out"     input="subFL:In 2" }
                { output = "keepR:Out"     input="subFR:In 1" }
                { output = "mixCenterSubRear:Out"     input="subFR:In 2" }

                { output = "subFL:Out"     input="front_gain_L:Input" }
                { output = "subFR:Out"     input="front_gain_R:Input" }



                # LFE BASS: Create LFE Sound
                { output = "keepL:Out" input = "lfe_lp_FL:Input" }
                { output = "keepR:Out" input = "lfe_lp_FR:Input" }

                { output = "lfe_lp_FL:Output" input = "lfe_sum:In 1" }
                { output = "lfe_lp_FR:Output" input = "lfe_sum:In 2" }
                { output = "mixCenterSubRear:Out" input = "lfe_sum:In 3" }


                # FINAL APPLY to FINAL CHANNELS  ---
                { output = "front_gain_L:Output" input = "convFL:In" }
                { output = "front_gain_R:Output" input = "convFR:In" }
                { output = "rear_hpL:Output"  input="convRL:In" }
                { output = "rear_hpR:Output"  input="convRR:In" }


                # --- Step 4: Mixers to Center/Sub Convolvers ---
                { output = "center_gain_C:Output"  input = "convFC:In" }
                { output = "lfe_sum:Out" input = "convLFE:In" }
            ]

            inputs  = [ "keepL:In" "keepR:In" ] 
            outputs = [ "convFL:Out" "convFR:Out" "convFC:Out" "convLFE:Out" "convRL:Out" "convRR:Out" ]
        }
        capture.props = {
            node.name      = "sbx_input"
            media.class    = Audio/Sink
            audio.channels = 2
            audio.position = [ FL FR ]
            node.force-rate = 48000
        }
        playback.props = {
            node.name      = "sbx_output"
            node.passive   = true
            audio.channels = 6
            audio.position = [ FL FR FC LFE RL RR ]
            #node.target = "@DEFAULT_SINK@"
            node.force-rate = 48000
            stream.dont-remix = true
        }
    }
}
]
